# =============================================================================
# E-Commerce API — Environment Variables
# =============================================================================
#
# SETUP INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in every value marked ← REQUIRED
#   3. Never commit your .env file — it is in .gitignore
#
# WHERE TO FIND EACH VALUE:
#   Supabase values → https://supabase.com/dashboard → your project → Settings → API
#   Paystack values → https://dashboard.paystack.com → Settings → API Keys & Webhooks
#
# =============================================================================


# ─── Application ─────────────────────────────────────────────────────────────

# Human-readable name shown in Swagger UI and logs
APP_NAME="E-Commerce API"

# Semantic version — update with each release
APP_VERSION="1.0.0"

# Environment identifier: development | staging | production
# Controls: Swagger docs visibility, log format (JSON vs pretty), debug mode
APP_ENV=development

# Enable verbose debug logging and Swagger UI
# Set to false in staging and production
DEBUG=true


# ─── Supabase ─────────────────────────────────────────────────────────────────
# All four values are REQUIRED. The app will not start without them.
# Found at: Supabase Dashboard → Settings → API

# Your Supabase project URL
# Format: https://<project-ref>.supabase.co
SUPABASE_URL="https://ohudxnauhoauegkqccxs.supabase.co"       # ← REQUIRED

# Public anon key — safe to use in browser, respects RLS
SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im9odWR4bmF1aG9hdWVna3FjY3hzIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzYyMzg2NTgsImV4cCI6MjA5MTgxNDY1OH0.qC8dNdToSuy7RZNeSv8yEib6TKWG44SVx7XoxzNZYDY"

# Service role key — bypasses RLS, used only by the backend
# NEVER expose this to the client/browser
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im9odWR4bmF1aG9hdWVna3FjY3hzIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3NjIzODY1OCwiZXhwIjoyMDkxODE0NjU4fQ.wshddEYwShuLx6XBiYRtWFadJ59PvlPSqGq9qV4r7ro"

# JWT signing secret — used to verify Supabase-issued access tokens
# Found at: Supabase Dashboard → Settings → API → JWT Secret (scroll down)
SUPABASE_JWT_SECRET="U9QUKlqHVt2MF+m1rFpCBtOhfWk4e+bidCqm48QrOW9THDISHfIVS4mwWuEoHf4H1dBEziuapJjcIBz7D5/Igw=="


# ─── Paystack (Payment Gateway) ───────────────────────────────────────────────
# Found at: https://dashboard.paystack.com → Settings → API Keys & Webhooks
#
# Use TEST keys (sk_test_...) during development
# Use LIVE keys (sk_live_...) in production only

# Secret key — used server-side to call Paystack API and verify webhooks
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # ← REQUIRED for payments

# Public key — returned in API responses for client-side Paystack integration
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # ← REQUIRED for payments

# Webhook signing secret — used to verify HMAC-SHA512 webhook signatures
# Found at: Paystack Dashboard → Settings → API Keys & Webhooks → Webhook section
# For local testing you can set this to any string and skip webhook verification
PAYSTACK_WEBHOOK_SECRET=your-paystack-webhook-secret                  # ← REQUIRED for payments


# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# No trailing slashes. No wildcards in production.
#
# Development example:
allowed_origins=["http://localhost:3000","http://localhost:5173","http://localhost:5174","https://vendora-customer-ui.onrender.com","https://vendora-admin-ui.onrender.com"]
#
# Production example (uncomment and update):
# ALLOWED_ORIGINS=https://yourshop.com,https://www.yourshop.com
